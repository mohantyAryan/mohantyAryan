# Copy this file to .env and fill in the key(s) you want to use.

# Groq (default backend, free) — get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gemini (optional, use --backend gemini) — get your key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Claude (optional, use --backend claude) — get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
